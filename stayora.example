# Stayora Environment Variables
# Copy this file to .env and fill in your values

# Secret key for Flask sessions (change this in production!)
SECRET_KEY=your-secret-key-change-this

# Database connection
DATABASE_URL=mysql+pymysql://root:@localhost:3306/stayora_db

# Google OAuth Credentials
# Get these from: https://console.cloud.google.com/ > APIs & Services > Credentials
# Create OAuth 2.0 Client ID (Web application)
# Add authorized redirect URI: http://localhost:5000/auth/google-callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe API Keys (optional - for payments)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
